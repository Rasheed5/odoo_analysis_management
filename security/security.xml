<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record model="ir.module.category" id="module_category_analysis_management">
            <field name="name">Analysis</field>
            <field name="description">Helps you manage your analysis team.</field>
            <field name="sequence">10</field>
        </record>

        <record id="group_analysis_readonly" model="res.groups">
            <field name="name">Read-only Stakeholder</field>
            <field name="category_id" ref="module_category_analysis_management"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Can read analysis requests and related records.</field>
        </record>

        <record id="group_analysis_user" model="res.groups">
            <field name="name">Analysis User</field>
            <field name="category_id" ref="module_category_analysis_management"/>
            <field name="implied_ids" eval="[(4, ref('group_analysis_readonly'))]"/>
            <field name="comment">Can create and edit analysis requests they own or are assigned to.</field>
        </record>

        <record id="group_analysis_reviewer" model="res.groups">
            <field name="name">Senior Analyst / Reviewer</field>
            <field name="category_id" ref="module_category_analysis_management"/>
            <field name="implied_ids" eval="[(4, ref('group_analysis_user'))]"/>
            <field name="comment">Can review requests and update status.</field>
        </record>

        <record id="group_analysis_manager" model="res.groups">
            <field name="name">Analysis Manager</field>
            <field name="category_id" ref="module_category_analysis_management"/>
            <field name="implied_ids" eval="[(4, ref('group_analysis_reviewer'))]"/>
            <field name="comment">Full access to all analysis records and settings.</field>
        </record>

        <!-- Record rules -->
        <!-- Just basic multi-company rules or similar if needed. We skip complex record rules per user instruction to keep "simple button-based state transitions" for now. -->

        <!-- Auto-assign admin group -->
        <record id="group_analysis_manager" model="res.groups">
            <field name="users" eval="[(4, ref('base.user_admin')), (4, ref('base.user_root'))]"/>
        </record>

    </data>
</odoo>
