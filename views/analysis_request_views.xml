<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List / Tree View -->
    <!-- Analysis Request List (List) View: Primary operational grid -->
    <record id="view_analysis_request_tree" model="ir.ui.view">
        <field name="name">analysis.request.tree</field>
        <field name="model">analysis.request</field>
        <field name="arch" type="xml">
            <list string="Analysis Requests" decoration-danger="is_overdue==True" decoration-success="state=='completed'" decoration-muted="state in ('closed', 'rejected')">
                <field name="name"/>
                <field name="title"/>
                <field name="project_id" optional="show"/>
                <field name="request_type" optional="show"/>
                <field name="priority" widget="badge" decoration-danger="priority == 'critical'" decoration-warning="priority == 'high'" decoration-info="priority == 'medium'" optional="show"/>
                <field name="requester_id" optional="show"/>
                <field name="analyst_ids" widget="many2many_tags" optional="show"/>
                <field name="reviewer_id" optional="hide"/>
                <field name="due_date" optional="show"/>
                <field name="state" widget="badge" decoration-success="state == 'completed'" decoration-info="state in ('in_progress', 'assigned')" decoration-warning="state in ('waiting_business', 'waiting_technical', 'pending_review')"/>
                <field name="is_overdue" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_analysis_request_form" model="ir.ui.view">
        <field name="name">analysis.request.form</field>
        <field name="model">analysis.request</field>
        <field name="arch" type="xml">
            <form string="Analysis Request">
                <header>
                    <button name="action_submit_for_review" string="Submit for Review" type="object" class="oe_highlight" invisible="state != 'new'"/>
                    
                    <!-- Approvals by reviewers / managers -->
                    <button name="action_approve" string="Approve" type="object" class="oe_highlight" invisible="state != 'under_review'" groups="group_analysis_reviewer,group_analysis_manager"/>
                    <button name="action_reject" string="Reject" type="object" invisible="state not in ('under_review', 'pending_review')" groups="group_analysis_reviewer,group_analysis_manager"/>
                    
                    <button name="action_assign" string="Assign" type="object" class="oe_highlight" invisible="state != 'approved'"/>
                    <button name="action_start_work" string="Start Work" type="object" class="oe_highlight" invisible="state not in ('assigned', 'waiting_business', 'waiting_technical')"/>
                    
                    <button name="action_mark_waiting_business" string="Wait on Business" type="object" invisible="state != 'in_progress'"/>
                    <button name="action_mark_waiting_technical" string="Wait on Technical" type="object" invisible="state != 'in_progress'"/>
                    
                    <button name="action_submit_for_final_review" string="Submit for Final Review" type="object" class="oe_highlight" invisible="state != 'in_progress'"/>
                    
                    <!-- Mark Completed by managers/reviewers typically or analysts -->
                    <button name="action_mark_completed" string="Mark Completed" type="object" class="oe_highlight" invisible="state != 'pending_review'" groups="group_analysis_reviewer,group_analysis_manager"/>
                    <button name="action_mark_completed" string="Mark Completed" type="object" invisible="state != 'in_progress'"/>
                    
                    <button name="action_close" string="Close" type="object" invisible="state not in ('completed', 'rejected')" groups="group_analysis_manager"/>
                    <button name="action_reset_to_new" string="Reset to New" type="object" invisible="state not in ('rejected', 'closed', 'assigned')" groups="group_analysis_manager"/>
                    
                    <field name="state" widget="statusbar" statusbar_visible="new,under_review,approved,assigned,in_progress,completed"/>
                </header>
                <sheet>
                    <!-- Smart Buttons: Navigation to related operational records -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_meetings" type="object" class="oe_stat_button" icon="fa-calendar">
                            <field name="meeting_count" widget="statinfo" string="Meetings"/>
                        </button>
                        <button name="action_view_requirements" type="object" class="oe_stat_button" icon="fa-list-ol">
                            <field name="requirement_count" widget="statinfo" string="Requirements"/>
                        </button>
                        <button name="action_view_deliverables" type="object" class="oe_stat_button" icon="fa-file-text-o">
                            <field name="deliverable_count" widget="statinfo" string="Deliverables"/>
                        </button>
                        <button name="action_view_action_items" type="object" class="oe_stat_button" icon="fa-check-square-o">
                            <field name="action_item_count" widget="statinfo" string="Action Items"/>
                        </button>
                    </div>
                    <!-- Status Ribbon: Visual indicator of the current lifecycle stage -->
                    <widget name="web_ribbon" title="Completed" bg_color="bg-success" invisible="state != 'completed'"/>
                    <widget name="web_ribbon" title="Closed" bg_color="bg-secondary" invisible="state != 'closed'"/>
                    <widget name="web_ribbon" title="Overdue" bg_color="bg-danger" invisible="is_overdue == False"/>

                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                        <h2>
                            <field name="title" placeholder="e.g. Implement New Payment Gateway" readonly="state in ('completed', 'closed')"/>
                        </h2>
                        <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}" placeholder="Tags..." readonly="state in ('completed', 'closed')"/>
                    </div>

                    <group>
                        <group string="Classification">
                            <field name="project_id" readonly="state in ('completed', 'closed')"/>
                            <field name="request_type" readonly="state in ('completed', 'closed')"/>
                            <field name="priority" widget="priority" readonly="state in ('completed', 'closed')"/>
                            <field name="business_domain" readonly="state in ('completed', 'closed')"/>
                            <field name="related_system_module" readonly="state in ('completed', 'closed')"/>
                        </group>
                        <group string="Ownership">
                            <field name="requester_id" readonly="state in ('completed', 'closed')"/>
                            <field name="analyst_ids" widget="many2many_tags" readonly="state in ('completed', 'closed')"/>
                            <field name="reviewer_id" readonly="state in ('completed', 'closed')"/>
                            <field name="manager_id" readonly="state in ('completed', 'closed')"/>
                        </group>
                        <group string="Dates &amp; Effort">
                            <field name="date_requested" readonly="state in ('completed', 'closed')"/>
                            <field name="date_assigned" readonly="1"/>
                            <field name="due_date" readonly="state in ('completed', 'closed')"/>
                            <field name="start_date" readonly="1"/>
                            <field name="completed_date" readonly="1"/>
                            <field name="is_overdue" invisible="1"/>
                        </group>
                        <group string="Tracking">
                            <field name="estimated_effort_hours" readonly="state in ('completed', 'closed')"/>
                            <field name="actual_effort_hours" readonly="state in ('completed', 'closed')"/>
                            <field name="days_open"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Overview" name="overview">
                            <group>
                                <field name="description" nolabel="0" placeholder="Detailed description of the request..."/>
                                <field name="business_objective" nolabel="0" placeholder="What is the main business goal?"/>
                                <field name="expected_output" nolabel="0" placeholder="What deliverables are expected?"/>
                            </group>
                        </page>
                        <page string="Scope &amp; Risks" name="scope_risks">
                            <group>
                                <field name="scope_summary"/>
                                <field name="constraints"/>
                                <field name="assumptions"/>
                                <field name="risks"/>
                            </group>
                        </page>
                        <page string="Internal Notes" name="internal_notes" groups="group_analysis_user">
                            <field name="internal_note" placeholder="Notes for the analysis team..."/>
                        </page>
                        <page string="Requirements" name="requirements">
                            <field name="requirement_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="title"/>
                                    <field name="type"/>
                                    <field name="priority" widget="badge" decoration-danger="priority == 'critical'" decoration-warning="priority == 'high'"/>
                                    <field name="state" widget="badge" decoration-success="state == 'approved'"/>
                                </list>
                            </field>
                        </page>
                        <page string="Deliverables" name="deliverables">
                            <field name="deliverable_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="title"/>
                                    <field name="type"/>
                                    <field name="state" widget="badge" decoration-success="state == 'approved'"/>
                                </list>
                            </field>
                        </page>
                        <page string="Meetings" name="meetings">
                            <field name="meeting_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="meeting_datetime"/>
                                    <field name="meeting_type"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                        <page string="Action Items" name="action_items">
                            <field name="action_item_ids" readonly="1">
                                <list>
                                    <field name="reference"/>
                                    <field name="name"/>
                                    <field name="owner_id"/>
                                    <field name="due_date"/>
                                    <field name="state" widget="badge" decoration-success="state == 'done'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_analysis_request_search" model="ir.ui.view">
        <field name="name">analysis.request.search</field>
        <field name="model">analysis.request</field>
        <field name="arch" type="xml">
            <search string="Search Analysis Requests">
                <field name="name"/>
                <field name="title"/>
                <field name="project_id"/>
                <field name="analyst_ids"/>
                <field name="tag_ids"/>
                
                <filter string="My Requests" name="my_requests" domain="[('requester_id', '=', uid)]"/>
                <filter string="Assigned to Me" name="assigned_to_me" domain="[('analyst_ids', 'in', uid)]"/>
                <filter string="Created by Me" name="created_by_me" domain="[('create_uid', '=', uid)]"/>
                <separator/>
                <filter string="Overdue" name="overdue" domain="[('is_overdue', '=', True)]"/>
                <filter string="High Priority" name="high_priority" domain="[('priority', 'in', ['high', 'critical'])]"/>
                <filter string="Critical Priority" name="critical_priority" domain="[('priority', '=', 'critical')]"/>
                <separator/>
                <filter string="Open Requests" name="open_requests" domain="[('state', 'not in', ['completed', 'closed', 'rejected'])]"/>
                <filter string="Waiting for Business" name="waiting_business" domain="[('state', '=', 'waiting_business')]"/>
                <filter string="Waiting for Technical" name="waiting_technical" domain="[('state', '=', 'waiting_technical')]"/>
                <filter string="Pending Review" name="pending_review" domain="[('state', '=', 'pending_review')]"/>
                <filter string="Completed" name="completed" domain="[('state', '=', 'completed')]"/>
                <filter string="Closed" name="closed" domain="[('state', '=', 'closed')]"/>

                <group expand="0" string="Group By">
                    <filter string="State" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Priority" name="group_by_priority" context="{'group_by': 'priority'}"/>
                    <filter string="Request Type" name="group_by_request_type" context="{'group_by': 'request_type'}"/>
                    <filter string="Requester" name="group_by_requester" context="{'group_by': 'requester_id'}"/>
                    <filter string="Assigned Analysts" name="group_by_analysts" context="{'group_by': 'analyst_ids'}"/>
                    <filter string="Reviewer" name="group_by_reviewer" context="{'group_by': 'reviewer_id'}"/>
                    <filter string="Due Date" name="group_by_due_date" context="{'group_by': 'due_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_analysis_request_kanban" model="ir.ui.view">
        <field name="name">analysis.request.kanban</field>
        <field name="model">analysis.request</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column" sample="1">
                <field name="state"/>
                <field name="name"/>
                <field name="title"/>
                <field name="priority"/>
                <field name="analyst_ids"/>
                <field name="due_date"/>
                <field name="is_overdue"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click o_kanban_record_has_image_fill {{ record.is_overdue.raw_value ? 'oe_kanban_color_alert' : '' }}">
                            <div class="oe_kanban_details">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title"><field name="name"/></strong>
                                    </div>
                                    <div class="o_dropdown_kanban dropdown">
                                        <a role="button" class="dropdown-toggle o-no-caret btn" data-bs-toggle="dropdown" data-bs-display="static" href="#" aria-label="Dropdown menu" title="Dropdown menu">
                                            <span class="fa fa-ellipsis-v"/>
                                        </a>
                                        <div class="dropdown-menu" role="menu">
                                            <a role="menuitem" type="edit" class="dropdown-item">Edit</a>
                                            <a role="menuitem" type="delete" class="dropdown-item">Delete</a>
                                        </div>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div><field name="title"/></div>
                                    <div t-if="record.due_date.value" t-attf-class="{{ record.is_overdue.raw_value ? 'text-danger' : '' }}">
                                        Due: <field name="due_date"/>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="priority" widget="priority"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="analyst_ids" widget="many2many_tags"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Graph View -->
    <record id="view_analysis_request_graph" model="ir.ui.view">
        <field name="name">analysis.request.graph</field>
        <field name="model">analysis.request</field>
        <field name="arch" type="xml">
            <graph string="Analysis Requests" type="bar" sample="1">
                <field name="state" type="row"/>
                <field name="request_type" type="col"/>
            </graph>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_analysis_request_pivot" model="ir.ui.view">
        <field name="name">analysis.request.pivot</field>
        <field name="model">analysis.request</field>
        <field name="arch" type="xml">
            <pivot string="Analysis Requests" sample="1">
                <field name="analyst_ids" type="row"/>
                <field name="state" type="col"/>
            </pivot>
        </field>
    </record>
</odoo>
