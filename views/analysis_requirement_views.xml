<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List / Tree View -->
    <!-- Requirement List View: Focused on MoSCoW priority and baseline state -->
    <record id="view_analysis_requirement_tree" model="ir.ui.view">
        <field name="name">analysis.requirement.tree</field>
        <field name="model">analysis.requirement</field>
        <field name="arch" type="xml">
            <list string="Requirements" decoration-bf="id == parent_id" decoration-info="state == 'draft'" decoration-success="state == 'baseline'">
                <field name="name"/>
                <field name="title"/>
                <field name="request_id" optional="show"/>
                <field name="type"/>
                <field name="owner_id" widget="many2one_avatar_user"/>
                <field name="analyst_ids" widget="many2many_tags" optional="show"/>
                <field name="reviewer_id" widget="many2one_avatar_user" optional="show"/>
                <field name="priority" widget="badge" decoration-danger="priority == 'critical'" decoration-warning="priority == 'high'" decoration-info="priority == 'medium'"/>
                <field name="complexity" optional="show"/>
                <field name="version"/>
                <field name="state" widget="badge" decoration-success="state == 'approved'" decoration-info="state == 'in_review'" decoration-danger="state == 'rejected'" decoration-muted="state == 'obsolete'"/>
            </list>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_analysis_requirement_kanban" model="ir.ui.view">
        <field name="name">analysis.requirement.kanban</field>
        <field name="model">analysis.requirement</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="state"/>
                <field name="priority"/>
                <field name="name"/>
                <field name="title"/>
                <field name="type"/>
                <field name="owner_id"/>
                <field name="version"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <span class="text-muted"><field name="name"/> - </span>
                                            <field name="title"/>
                                        </strong>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body mt-2 mb-2">
                                    <div class="text-muted" style="font-size: 0.9em;">
                                        <field name="type"/> • v<field name="version"/>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="priority" widget="label_selection" options="{'classes': {'critical': 'danger', 'high': 'warning', 'medium': 'info', 'low': 'default'}}"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="owner_id" widget="many2one_avatar_user"/>
                                        <field name="analyst_ids" widget="many2many_tags"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_analysis_requirement_form" model="ir.ui.view">
        <field name="name">analysis.requirement.form</field>
        <field name="model">analysis.requirement</field>
        <field name="arch" type="xml">
            <form string="Analysis Requirement">
                <header>
                    <button name="action_submit_review" string="Submit for Review" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object" class="oe_highlight" invisible="state != 'in_review'" groups="analysis_management.group_analysis_reviewer,analysis_management.group_analysis_manager"/>
                    <button name="action_reject" string="Reject" type="object" invisible="state != 'in_review'" groups="analysis_management.group_analysis_reviewer,analysis_management.group_analysis_manager"/>
                    <button name="action_mark_obsolete" string="Mark Obsolete" type="object" invisible="state not in ('draft', 'approved')" groups="analysis_management.group_analysis_manager"/>
                    <button name="action_reset_to_draft" string="Reset to Draft" type="object" invisible="state == 'draft'" groups="analysis_management.group_analysis_reviewer,analysis_management.group_analysis_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,in_review,approved"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_meetings" type="object" class="oe_stat_button" icon="fa-users">
                            <field name="meeting_count" widget="statinfo" string="Meetings"/>
                        </button>
                        <button name="action_view_action_items" type="object" class="oe_stat_button" icon="fa-check-square-o">
                            <field name="action_item_count" widget="statinfo" string="Action Items"/>
                        </button>
                        <button name="action_view_deliverables" type="object" class="oe_stat_button" icon="fa-file-text-o">
                            <field name="deliverable_count" widget="statinfo" string="Deliverables"/>
                        </button>
                    </div>

                    <widget name="web_ribbon" title="Approved" bg_color="bg-success" invisible="state != 'approved'"/>
                    <widget name="web_ribbon" title="Rejected" bg_color="bg-danger" invisible="state != 'rejected'"/>
                    <widget name="web_ribbon" title="Obsolete" bg_color="bg-secondary" invisible="state != 'obsolete'"/>
                    
                    <div class="oe_title">
                        <h2>
                            <field name="name"/>
                        </h2>
                        <h1>
                            <field name="title" nolabel="1" placeholder="e.g. System should allow users to export data to CSV..."/>
                        </h1>
                        <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}" placeholder="Tags..."/>
                    </div>

                    <group>
                        <group string="Configuration">
                            <field name="request_id"/>
                            <field name="project_id"/>
                            <field name="type"/>
                            <field name="priority"/>
                            <field name="complexity"/>
                        </group>
                        <group string="Ownership &amp; Status">
                            <field name="owner_id" widget="many2one_avatar_user"/>
                            <field name="analyst_ids" widget="many2many_tags"/>
                            <field name="reviewer_id" widget="many2one_avatar_user"/>
                            <field name="version"/>
                            <field name="approved_date" invisible="state != 'approved'"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Requirement Details" name="requirement_details">
                            <group>
                                <field name="description" nolabel="0" placeholder="Thorough description of the requirement..."/>
                                <field name="source" nolabel="0" placeholder="Origin of requirement (e.g., Legislative mandate, specific stakeholder)..."/>
                                <field name="business_rules" nolabel="0" placeholder="Specific business rules applied here..."/>
                                <field name="acceptance_criteria" nolabel="0" placeholder="Given... When... Then..."/>
                            </group>
                        </page>
                        <page string="Analysis Context" name="analysis_context">
                            <group>
                                <field name="dependencies" nolabel="0" placeholder="What must happen before this is implemented..."/>
                                <field name="assumptions" nolabel="0" placeholder="Assumptions made holding this requirement true..."/>
                                <field name="constraints" nolabel="0" placeholder="Technical or business constraints..."/>
                                <field name="notes" nolabel="0" placeholder="General internal notes..."/>
                            </group>
                        </page>
                        <page string="Linked Records" name="linked_records">
                            <group string="Sourced from Meetings">
                                <field name="meeting_ids" widget="many2many_tags" nolabel="1"/>
                            </group>
                            <group string="Associated Deliverables">
                                <field name="deliverable_ids" widget="many2many_tags" nolabel="1" domain="[('request_id', '=', request_id)]"/>
                            </group>
                            <group string="Follow-up Action Items">
                                <field name="action_item_ids" nolabel="1">
                                    <list>
                                        <field name="reference" optional="show"/>
                                        <field name="name"/>
                                        <field name="owner_id"/>
                                        <field name="priority"/>
                                        <field name="state" widget="badge"/>
                                    </list>
                                </field>
                            </group>
                        </page>
                        <page string="Review" name="review" invisible="state == 'draft'">
                            <group>
                                <field name="approval_comment" nolabel="0" placeholder="Comments from the reviewer regarding approval/rejection..." readonly="not context.get('uid') == reviewer_id and not context.get('uid') == owner_id"/> <!-- Typically restricted but left editable based on spec -->
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_analysis_requirement_search" model="ir.ui.view">
        <field name="name">analysis.requirement.search</field>
        <field name="model">analysis.requirement</field>
        <field name="arch" type="xml">
            <search string="Search Requirements">
                <field name="name"/>
                <field name="title"/>
                <field name="owner_id"/>
                <field name="reviewer_id"/>
                <field name="analyst_ids"/>
                <field name="request_id"/>
                <field name="tag_ids"/>
                
                <filter string="My Requirements" name="my_requirements" domain="[('owner_id', '=', uid)]"/>
                <filter string="Assigned to Me (Review)" name="my_reviews" domain="[('reviewer_id', '=', uid)]"/>
                <separator/>
                <filter string="Draft" name="state_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="In Review" name="state_in_review" domain="[('state', '=', 'in_review')]"/>
                <filter string="Approved" name="state_approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Rejected" name="state_rejected" domain="[('state', '=', 'rejected')]"/>
                <filter string="Obsolete" name="state_obsolete" domain="[('state', '=', 'obsolete')]"/>
                <separator/>
                <filter string="High Priority" name="priority_high" domain="[('priority', '=', 'high')]"/>
                <filter string="Critical Priority" name="priority_critical" domain="[('priority', '=', 'critical')]"/>
                <separator/>
                <filter string="With Acceptance Criteria" name="has_acceptance_criteria" domain="[('has_acceptance_criteria', '=', True)]"/>
                <filter string="With Dependencies" name="has_dependencies" domain="[('has_dependencies', '=', True)]"/>
                <filter string="Linked to Request" name="linked_request" domain="[('request_id', '!=', False)]"/>

                <group expand="0" string="Group By">
                    <filter string="State" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Requirement Type" name="group_by_type" context="{'group_by': 'type'}"/>
                    <filter string="Priority" name="group_by_priority" context="{'group_by': 'priority'}"/>
                    <filter string="Complexity" name="group_by_complexity" context="{'group_by': 'complexity'}"/>
                    <filter string="Owner" name="group_by_owner" context="{'group_by': 'owner_id'}"/>
                    <filter string="Assigned Analysts" name="group_by_analysts" context="{'group_by': 'analyst_ids'}"/>
                    <filter string="Reviewer" name="group_by_reviewer" context="{'group_by': 'reviewer_id'}"/>
                    <filter string="Request" name="group_by_request" context="{'group_by': 'request_id'}"/>
                    <filter string="Version" name="group_by_version" context="{'group_by': 'version'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Graph View -->
    <record id="view_analysis_requirement_graph" model="ir.ui.view">
        <field name="name">analysis.requirement.graph</field>
        <field name="model">analysis.requirement</field>
        <field name="arch" type="xml">
            <graph string="Requirements" type="bar" sample="1">
                <field name="type" type="row"/>
                <field name="state" type="col"/>
            </graph>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_analysis_requirement_pivot" model="ir.ui.view">
        <field name="name">analysis.requirement.pivot</field>
        <field name="model">analysis.requirement</field>
        <field name="arch" type="xml">
            <pivot string="Requirements" sample="1">
                <field name="owner_id" type="row"/>
                <field name="state" type="col"/>
            </pivot>
        </field>
    </record>

</odoo>
