<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tag Form View -->
    <record id="view_analysis_tag_form" model="ir.ui.view">
        <field name="name">analysis.tag.form</field>
        <field name="model">analysis.tag</field>
        <field name="arch" type="xml">
            <form string="Analysis Tag">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="color" widget="color_picker"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tag List View -->
    <record id="view_analysis_tag_tree" model="ir.ui.view">
        <field name="name">analysis.tag.tree</field>
        <field name="model">analysis.tag</field>
        <field name="arch" type="xml">
            <list string="Analysis Tags" editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <!-- Tag Action -->
    <record id="action_analysis_tag" model="ir.actions.act_window">
        <field name="name">Analysis Tags</field>
        <field name="res_model">analysis.tag</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Analysis Tag
            </p>
            <p>
                Tags help you categorize requests, requirements, and deliverables across the entire analysis lifecycle.
            </p>
        </field>
    </record>
</odoo>
