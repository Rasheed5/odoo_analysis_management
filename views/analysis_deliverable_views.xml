<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List / Tree View -->
    <!-- Deliverable List View: Document matrix for the analysis phase -->
    <record id="view_analysis_deliverable_tree" model="ir.ui.view">
        <field name="name">analysis.deliverable.tree</field>
        <field name="model">analysis.deliverable</field>
        <field name="arch" type="xml">
            <list string="Deliverables" decoration-danger="is_overdue==True" decoration-success="state == 'approved'" decoration-muted="state == 'finalized'">
                <field name="name"/>
                <field name="title"/>
                <field name="type" optional="show"/>
                <field name="project_id" optional="show"/>
                <field name="request_id" optional="show"/>
                <field name="analyst_ids" widget="many2many_tags" optional="show"/>
                <field name="reviewer_id" widget="many2one_avatar_user" optional="show"/>
                <field name="version" optional="show"/>
                <field name="planned_due_date"/>
                <field name="submission_date" optional="show"/>
                <field name="approval_date" optional="show"/>
                <field name="is_overdue" column_invisible="True"/>
                <field name="state" widget="badge" decoration-success="state == 'approved'" decoration-info="state == 'in_progress'" decoration-warning="state == 'pending_review'" decoration-danger="state == 'rejected'" decoration-muted="state == 'finalized'"/>
            </list>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_analysis_deliverable_kanban" model="ir.ui.view">
        <field name="name">analysis.deliverable.kanban</field>
        <field name="model">analysis.deliverable</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="state"/>
                <field name="name"/>
                <field name="title"/>
                <field name="type"/>
                <field name="analyst_ids"/>
                <field name="reviewer_id"/>
                <field name="planned_due_date"/>
                <field name="is_overdue"/>
                <field name="version"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <span class="text-muted"><field name="name"/> - </span>
                                            <field name="title"/>
                                        </strong>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body mt-2 mb-2">
                                    <div class="text-muted" style="font-size: 0.9em;">
                                        <field name="type"/> • v<field name="version"/>
                                    </div>
                                    <div t-if="record.is_overdue.raw_value" class="text-danger fw-bold mt-1">
                                        <i class="fa fa-exclamation-triangle"/> Overdue: <field name="planned_due_date"/>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <!-- Review cycles or metadata could go here -->
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="analyst_ids" widget="many2many_tags"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_analysis_deliverable_form" model="ir.ui.view">
        <field name="name">analysis.deliverable.form</field>
        <field name="model">analysis.deliverable</field>
        <field name="arch" type="xml">
            <form string="Analysis Deliverable">
                <header>
                    <button name="action_start_drafting" string="Start Drafting" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_submit_review" string="Submit for Review" type="object" class="oe_highlight" invisible="state not in ['in_progress', 'review_feedback']"/>
                    <button name="action_send_back" string="Send Back for Revision" type="object" invisible="state != 'pending_review'" groups="group_analysis_reviewer,group_analysis_manager"/>
                    <button name="action_approve" string="Approve" type="object" class="oe_highlight" invisible="state != 'pending_review'" groups="group_analysis_reviewer,group_analysis_manager"/>
                    <button name="action_reject" string="Reject" type="object" invisible="state != 'pending_review'" groups="group_analysis_reviewer,group_analysis_manager"/>
                    <button name="action_finalize" string="Finalize" type="object" class="oe_highlight" invisible="state != 'approved'" groups="group_analysis_manager"/>
                    <button name="action_reset_to_draft" string="Reset to Draft" type="object" invisible="state == 'draft'" groups="group_analysis_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,pending_review,approved,finalized"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_requirements" type="object" class="oe_stat_button" icon="fa-list-ol">
                            <field name="requirement_count" widget="statinfo" string="Requirements"/>
                        </button>
                        <button name="action_view_action_items" type="object" class="oe_stat_button" icon="fa-check-square-o">
                            <field name="action_item_count" widget="statinfo" string="Action Items"/>
                        </button>
                        <button name="action_view_meetings" type="object" class="oe_stat_button" icon="fa-users">
                            <field name="meeting_count" widget="statinfo" string="Meetings"/>
                        </button>
                    </div>

                    <widget name="web_ribbon" title="Overdue" bg_color="bg-danger" invisible="is_overdue == False"/>
                    <widget name="web_ribbon" title="Approved" bg_color="bg-success" invisible="state != 'approved'"/>
                    <widget name="web_ribbon" title="Finalized" bg_color="bg-primary" invisible="state != 'finalized'"/>
                    
                    <div class="oe_title">
                        <h2>
                            <field name="name"/>
                        </h2>
                        <h1>
                            <field name="title" nolabel="1" placeholder="e.g. BRD - Vendor Portal Phase 1..."/>
                        </h1>
                        <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}" placeholder="Tags..."/>
                    </div>

                    <group>
                        <group string="Core Details">
                            <field name="type"/>
                            <field name="request_id"/>
                            <field name="project_id"/>
                            <field name="analyst_ids" widget="many2many_tags"/>
                            <field name="reviewer_id" widget="many2one_avatar_user"/>
                        </group>
                        <group string="Status &amp; Timeline">
                            <field name="version"/>
                            <field name="planned_due_date"/>
                            <field name="submission_date"/>
                            <field name="approval_date"/>
                            <field name="review_cycle_count" readonly="1" invisible="review_cycle_count == 0"/>
                            <field name="is_overdue" invisible="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Overview &amp; Summary" name="summary">
                            <group>
                                <field name="summary" nolabel="0" placeholder="Executive summary of this deliverable..."/>
                            </group>
                        </page>
                        <page string="Linked Records" name="linked_records">
                            <group string="Associated Requirements">
                                <field name="requirement_ids" widget="many2many_tags" nolabel="1" domain="[('request_id', '=', request_id)]"/>
                            </group>
                            <group string="Related Meetings">
                                <field name="meeting_ids" widget="many2many_tags" nolabel="1"/>
                            </group>
                            <group string="Action Items &amp; Sub-tasks">
                                <field name="action_item_ids" nolabel="1">
                                    <list>
                                        <field name="reference" optional="show"/>
                                        <field name="name"/>
                                        <field name="owner_id"/>
                                        <field name="priority"/>
                                        <field name="state" widget="badge"/>
                                    </list>
                                </field>
                            </group>
                        </page>
                        <page string="Review &amp; Sign-off" name="review">
                            <group>
                                <field name="review_comments" nolabel="0" placeholder="Reviewer feedback and required corrections..." readonly="state not in ('pending_review', 'review_feedback')"/>
                                <field name="final_note" nolabel="0" placeholder="Final comments upon approval/finalization..." invisible="state not in ('approved', 'finalized')"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_analysis_deliverable_search" model="ir.ui.view">
        <field name="name">analysis.deliverable.search</field>
        <field name="model">analysis.deliverable</field>
        <field name="arch" type="xml">
            <search string="Search Deliverables">
                <field name="name"/>
                <field name="title"/>
                <field name="project_id"/>
                <field name="analyst_ids"/>
                <field name="reviewer_id"/>
                <field name="request_id"/>
                <field name="tag_ids"/>
                
                <filter string="My Deliverables" name="my_deliverables" domain="[('analyst_ids', 'in', uid)]"/>
                <filter string="Assigned to Me (Review)" name="my_reviews" domain="[('reviewer_id', '=', uid)]"/>
                <separator/>
                <filter string="Draft" name="state_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="In Progress" name="state_in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="Pending Review" name="state_pending_review" domain="[('state', '=', 'pending_review')]"/>
                <filter string="Review Feedback" name="state_review_feedback" domain="[('state', '=', 'review_feedback')]"/>
                <filter string="Approved" name="state_approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Rejected" name="state_rejected" domain="[('state', '=', 'rejected')]"/>
                <filter string="Finalized" name="state_finalized" domain="[('state', '=', 'finalized')]"/>
                <separator/>
                <filter string="Overdue" name="overdue" domain="[('is_overdue', '=', True)]"/>
                <filter string="Due Soon" name="due_soon" domain="[('planned_due_date', '&lt;=', (context_today() + datetime.timedelta(days=7)).strftime('%Y-%m-%d')), ('planned_due_date', '&gt;=', context_today().strftime('%Y-%m-%d')), ('state', 'not in', ('approved', 'finalized', 'rejected'))]"/>
                <separator/>
                <filter string="Linked to Request" name="linked_request" domain="[('request_id', '!=', False)]"/>
                <filter string="Linked to Requirements" name="linked_requirements" domain="[('requirement_ids', '!=', False)]"/>

                <group expand="0" string="Group By">
                    <filter string="State" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Deliverable Type" name="group_by_type" context="{'group_by': 'type'}"/>
                    <filter string="Analysts" name="group_by_analysts" context="{'group_by': 'analyst_ids'}"/>
                    <filter string="Reviewer" name="group_by_reviewer" context="{'group_by': 'reviewer_id'}"/>
                    <filter string="Request" name="group_by_request" context="{'group_by': 'request_id'}"/>
                    <filter string="Planned Due Date" name="group_by_due_date" context="{'group_by': 'planned_due_date'}"/>
                    <filter string="Version" name="group_by_version" context="{'group_by': 'version'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Graph View -->
    <record id="view_analysis_deliverable_graph" model="ir.ui.view">
        <field name="name">analysis.deliverable.graph</field>
        <field name="model">analysis.deliverable</field>
        <field name="arch" type="xml">
            <graph string="Deliverables" type="bar" sample="1">
                <field name="type" type="row"/>
                <field name="state" type="col"/>
            </graph>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_analysis_deliverable_pivot" model="ir.ui.view">
        <field name="name">analysis.deliverable.pivot</field>
        <field name="model">analysis.deliverable</field>
        <field name="arch" type="xml">
            <pivot string="Deliverables" sample="1">
                <field name="analyst_ids" type="row"/>
                <field name="state" type="col"/>
            </pivot>
        </field>
    </record>

</odoo>
