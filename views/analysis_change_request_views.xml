<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Change Request Tree View -->
    <record id="view_analysis_change_request_tree" model="ir.ui.view">
        <field name="name">analysis.change.request.tree</field>
        <field name="model">analysis.change.request</field>
        <field name="arch" type="xml">
            <list string="Change Requests" decoration-info="state == 'draft'" decoration-warning="state == 'under_review'" decoration-success="state == 'approved'">
                <field name="name"/>
                <field name="title"/>
                <field name="project_id"/>
                <field name="customer_id"/>
                <field name="date_received"/>
                <field name="priority" widget="badge" decoration-danger="priority == 'critical'" decoration-warning="priority == 'high'" decoration-info="priority == 'medium'"/>
                <field name="request_type" widget="badge"/>
                <field name="state" widget="badge" decoration-success="state in ('approved', 'converted', 'closed')" decoration-info="state in ('draft', 'submitted')" decoration-warning="state in ('under_review', 'pending_impact', 'pending_approval')"/>
            </list>
        </field>
    </record>

    <!-- Change Request Kanban View -->
    <record id="view_analysis_change_request_kanban" model="ir.ui.view">
        <field name="name">analysis.change.request.kanban</field>
        <field name="model">analysis.change.request</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" sample="1">
                <field name="name"/>
                <field name="title"/>
                <field name="project_id"/>
                <field name="priority"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_record_top">
                            <div class="o_kanban_record_headings">
                                <strong class="o_kanban_record_title"><field name="title"/></strong>
                                <div><field name="name"/></div>
                            </div>
                        </div>
                        <div class="o_kanban_record_body">
                            <field name="project_id"/>
                        </div>
                        <div class="o_kanban_record_bottom mt-auto d-flex justify-content-between align-items-center">
                            <field name="priority" widget="priority"/>
                            <field name="state" widget="label_selection" options="{'classes': {'draft': 'info', 'approved': 'success', 'rejected': 'danger'}}"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Change Request Form View -->
    <record id="view_analysis_change_request_form" model="ir.ui.view">
        <field name="name">analysis.change.request.form</field>
        <field name="model">analysis.change.request</field>
        <field name="arch" type="xml">
            <form string="Change Request">
                <header>
                    <button name="action_submit" string="Submit" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_review" string="Start Review" type="object" class="oe_highlight" invisible="state != 'submitted'"/>
                    <button name="action_analyze_impact" string="Analyze Impact" type="object" invisible="state != 'under_review'"/>
                    <button name="action_ready_for_approval" string="Ready for Approval" type="object" class="oe_highlight" invisible="state != 'pending_impact'"/>
                    <button name="action_approve" string="Approve" type="object" class="oe_highlight" invisible="state != 'pending_approval'" groups="analysis_management.group_analysis_manager"/>
                    <button name="action_postpone" string="Postpone" type="object" invisible="state != 'pending_approval'" groups="analysis_management.group_analysis_manager"/>
                    <button name="action_reject" string="Reject" type="object" invisible="state != 'pending_approval'" groups="analysis_management.group_analysis_manager"/>
                    <button name="action_convert_to_analysis" string="Convert to Analysis" type="object" class="oe_highlight" invisible="state != 'approved' or analysis_request_id"/>
                    <button name="action_close" string="Close" type="object" invisible="state not in ('approved', 'converted')"/>
                    <button name="action_reset_to_draft" string="Reset to Draft" type="object" invisible="state not in ('rejected', 'postponed')"/>
                    
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,under_review,pending_impact,pending_approval,approved"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_analysis_request" type="object" class="oe_stat_button" icon="fa-file-text-o" invisible="not analysis_request_id">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Analysis Req</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Project Information">
                            <field name="project_id" options="{'no_create': True}"/>
                            <field name="project_code"/>
                            <field name="current_phase_name"/>
                            <field name="phase_number"/>
                            <field name="customer_id"/>
                            <field name="system_version"/>
                            <field name="contract_date"/>
                        </group>
                        <group string="CR General Information">
                            <field name="title" placeholder="e.g. Add Payment Gateway Management"/>
                            <field name="date_received"/>
                            <field name="receiver_id" options="{'no_create': True}"/>
                            <field name="request_reference"/>
                            <field name="submitted_by"/>
                            <field name="requester_role"/>
                            <field name="priority" widget="priority"/>
                            <field name="request_type"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <separator string="Background and Context"/>
                            <field name="background" placeholder="Describe the current situation and why this change is needed..."/>
                            <separator string="Scope Reference"/>
                            <field name="scope_reference" placeholder="Reference to original BRD or SRS section..."/>
                            <separator string="Detailed Description"/>
                            <field name="detailed_description" placeholder="Technical/Functional details of the requested change..."/>
                            <separator string="Justification"/>
                            <field name="justification" placeholder="Business value and necessity..."/>
                        </page>
                        <page string="Impact Analysis" name="impacts">
                            <group>
                                <group string="Scope Impact">
                                    <field name="phase_scope_impact"/>
                                    <field name="project_scope_impact"/>
                                    <field name="impact_category"/>
                                </group>
                                <group string="Schedule Impact">
                                    <field name="schedule_impact_level"/>
                                    <field name="schedule_impact_notes"/>
                                </group>
                            </group>
                            <group string="Resource &amp; Cost Impact">
                                <group>
                                    <field name="resource_impact_notes"/>
                                    <field name="pricing_model"/>
                                    <field name="cost_calculation_mechanism"/>
                                </group>
                                <group>
                                    <field name="days_analysis"/>
                                    <field name="days_config"/>
                                    <field name="days_dev"/>
                                    <field name="days_testing"/>
                                    <field name="days_training"/>
                                    <field name="estimated_work_days" class="oe_bold"/>
                                    <field name="estimated_cost" widget="monetary"/>
                                    <field name="billing_mechanism"/>
                                </group>
                            </group>
                        </page>
                        <page string="Affected Components" name="components">
                            <field name="component_ids">
                                <list editable="bottom">
                                    <field name="level"/>
                                    <field name="name"/>
                                </list>
                            </field>
                        </page>
                        <page string="Outputs &amp; Deliverables" name="outputs">
                            <field name="output_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                </list>
                            </field>
                        </page>
                        <page string="Stakeholders" name="stakeholders">
                            <field name="stakeholder_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="partner_id"/>
                                    <field name="title"/>
                                    <field name="impact_degree"/>
                                    <field name="impact_type"/>
                                    <field name="required_action"/>
                                </list>
                            </field>
                        </page>
                        <page string="Risks &amp; Mitigation" name="risks">
                            <field name="risk_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="probability"/>
                                    <field name="impact"/>
                                    <field name="risk_level"/>
                                    <field name="mitigation"/>
                                    <field name="owner_id"/>
                                </list>
                            </field>
                        </page>
                        <page string="Recommendations" name="alternatives">
                            <separator string="Proposed Alternatives"/>
                            <field name="proposed_alternatives"/>
                            <separator string="Company Recommendations"/>
                            <field name="final_recommendations"/>
                        </page>
                        <page string="Assumptions &amp; Constraints" name="assumptions">
                            <group>
                                <group string="Assumptions">
                                    <field name="assumption_ids" nolabel="1">
                                        <list editable="bottom">
                                            <field name="name"/>
                                        </list>
                                    </field>
                                </group>
                                <group string="Constraints">
                                    <field name="constraint_ids" nolabel="1">
                                        <list editable="bottom">
                                            <field name="name"/>
                                        </list>
                                    </field>
                                </group>
                            </group>
                        </page>
                        <page string="Approvals &amp; Sign-off" name="approvals">
                            <separator string="Mutual Declarations"/>
                            <field name="mutual_declarations"/>
                            <group>
                                <group string="Decision">
                                    <field name="client_decision"/>
                                </group>
                                <group string="Dates">
                                    <field name="requester_sign_date"/>
                                    <field name="approver_sign_date"/>
                                </group>
                            </group>
                            <group>
                                <group string="Requester">
                                    <field name="requester_sign_name"/>
                                    <field name="requester_sign_role"/>
                                </group>
                                <group string="Approver">
                                    <field name="approver_sign_name"/>
                                    <field name="approver_sign_role"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_analysis_change_request_search" model="ir.ui.view">
        <field name="name">analysis.change.request.search</field>
        <field name="model">analysis.change.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="title"/>
                <field name="project_id"/>
                <field name="customer_id"/>
                <filter string="My Requests" name="my_requests" domain="[('receiver_id', '=', uid)]"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Under Review" name="under_review" domain="[('state', '=', 'under_review')]"/>
                <filter string="Pending Approval" name="pending_approval" domain="[('state', '=', 'pending_approval')]"/>
                <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                <separator/>
                <filter string="High Priority" name="high_priority" domain="[('priority', 'in', ('high', 'critical'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Project" name="group_by_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Priority" name="group_by_priority" context="{'group_by': 'priority'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_analysis_change_request_pivot" model="ir.ui.view">
        <field name="name">analysis.change.request.pivot</field>
        <field name="model">analysis.change.request</field>
        <field name="arch" type="xml">
            <pivot string="Change Request Analytics">
                <field name="project_id" type="row"/>
                <field name="state" type="col"/>
                <field name="estimated_cost" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Action -->
    <record id="action_analysis_change_request" model="ir.actions.act_window">
        <field name="name">Change Requests</field>
        <field name="res_model">analysis.change.request</field>
        <field name="view_mode">list,kanban,form,pivot</field>
        <field name="search_view_id" ref="view_analysis_change_request_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Manage your Change Requests here
            </p>
            <p>
                Follow a formal governance process for project changes, analyze impacts, and convert approved requests into analysis tasks.
            </p>
        </field>
    </record>
</odoo>
