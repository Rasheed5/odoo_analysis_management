<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="analysis_management.AnalysisDashboard">
        <!-- Main Dashboard Container -->
        <div class="o_dashboard_container p-4">
            <t t-if="state.loading">
                <!-- Loading State: Displays while backend metrics are being computed -->
                <div class="d-flex justify-content-center align-items-center vh-100">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </t>
            <t t-else="">
                <!-- Section 1: KPI Cards - Strategic metric aggregation -->
                <div class="row g-3 mb-4">
                    <div class="col-12 col-md-3">
                        <div class="o_dashboard_card shadow-sm border-0 kpi-card-blue bg-view p-3 rounded-4 h-100 cursor-pointer" t-on-click="() => this.openRequests([['state', 'not in', ['completed', 'closed', 'rejected']]], 'Open Requests')">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="text-uppercase text-muted fw-bold small mb-1">Open Requests</h6>
                                    <h2 class="fw-bold mb-0 text-primary"><t t-esc="state.data.kpis.open_requests"/></h2>
                                </div>
                                <div class="bg-primary bg-opacity-10 p-2 rounded-3 text-primary">
                                    <i class="fa fa-folder-open fa-2x"/>
                                </div>
                            </div>
                            <div class="mt-2 text-muted small">Active in the pipeline</div>
                        </div>
                    </div>
                    <div class="col-12 col-md-3">
                        <div class="o_dashboard_card shadow-sm border-0 kpi-card-red bg-view p-3 rounded-4 h-100 cursor-pointer" t-on-click="() => this.openRequests([['is_overdue', '=', true]], 'Overdue Requests')">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="text-uppercase text-muted fw-bold small mb-1">Overdue Requests</h6>
                                    <h2 class="fw-bold mb-0 text-danger"><t t-esc="state.data.kpis.overdue_requests"/></h2>
                                </div>
                                <div class="bg-danger bg-opacity-10 p-2 rounded-3 text-danger">
                                    <i class="fa fa-clock-o fa-2x"/>
                                </div>
                            </div>
                            <div class="mt-2 text-danger small"><t t-esc="state.data.kpis.overdue_requests"/> needs immediate attention</div>
                        </div>
                    </div>
                    <div class="col-12 col-md-3">
                        <div class="o_dashboard_card shadow-sm border-0 kpi-card-purple bg-view p-3 rounded-4 h-100 cursor-pointer" t-on-click="() => this.openDeliverables([['state', '=', 'pending_review']], 'Pending Reviews')">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="text-uppercase text-muted fw-bold small mb-1">Pending Reviews</h6>
                                    <h2 class="fw-bold mb-0 text-info" style="color: #6f42c1 !important;"><t t-esc="state.data.kpis.pending_review_deliverables"/></h2>
                                </div>
                                <div class="bg-info bg-opacity-10 p-2 rounded-3" style="color: #6f42c1 !important; background-color: rgba(111, 66, 193, 0.1) !important;">
                                    <i class="fa fa-eye fa-2x"/>
                                </div>
                            </div>
                            <div class="mt-2 text-muted small">Deliverables awaiting sign-off</div>
                        </div>
                    </div>
                    <div class="col-12 col-md-3">
                        <div class="o_dashboard_card shadow-sm border-0 kpi-card-teal bg-view p-3 rounded-4 h-100 cursor-pointer" t-on-click="() => this.openMeetings([], 'Today\'s Meetings')">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="text-uppercase text-muted fw-bold small mb-1">Today's Meetings</h6>
                                    <h2 class="fw-bold mb-0 text-teal" style="color: #20c997 !important;"><t t-esc="state.data.kpis.meetings_today"/></h2>
                                </div>
                                <div class="bg-success bg-opacity-10 p-2 rounded-3" style="color: #20c997 !important; background-color: rgba(32, 201, 151, 0.1) !important;">
                                    <i class="fa fa-calendar-check-o fa-2x"/>
                                </div>
                            </div>
                            <div class="mt-2 text-muted small">Scheduled for today</div>
                        </div>
                    </div>
                </div>

                <!-- Section 2: Change Management Governance - Tracking formal project changes -->
                <div class="row g-3 mb-4">
                    <div class="col-12 col-md-3">
                        <div class="o_dashboard_card shadow-sm border-0 kpi-card-orange bg-view p-3 rounded-4 h-100 cursor-pointer" t-on-click="() => this.openChangeRequests([['state', 'not in', ['closed', 'rejected', 'converted']]], 'Open Change Requests')">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="text-uppercase text-muted fw-bold small mb-1">Open CRs</h6>
                                    <h2 class="fw-bold mb-0 text-warning" style="color: #fd7e14 !important;"><t t-esc="state.data.change_requests.total_open"/></h2>
                                </div>
                                <div class="bg-warning bg-opacity-10 p-2 rounded-3 text-warning" style="background-color: rgba(253, 126, 20, 0.1) !important; color: #fd7e14 !important;">
                                    <i class="fa fa-refresh fa-2x"/>
                                </div>
                            </div>
                            <div class="mt-2 text-muted small">Formal requests in pipe</div>
                        </div>
                    </div>
                    <div class="col-12 col-md-3">
                        <div class="o_dashboard_card shadow-sm border-0 kpi-card-orange bg-view p-3 rounded-4 h-100 cursor-pointer" t-on-click="() => this.openChangeRequests([['state', 'in', ['under_review', 'pending_impact']]], 'CRs Pending Analysis')">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="text-uppercase text-muted fw-bold small mb-1">Pending CR Analysis</h6>
                                    <h2 class="fw-bold mb-0 text-warning" style="color: #fd7e14 !important;"><t t-esc="state.data.change_requests.pending_impact"/></h2>
                                </div>
                                <div class="bg-warning bg-opacity-10 p-2 rounded-3 text-warning" style="background-color: rgba(253, 126, 20, 0.1) !important; color: #fd7e14 !important;">
                                    <i class="fa fa-flask fa-2x"/>
                                </div>
                            </div>
                            <div class="mt-2 text-muted small">Awaiting impact study</div>
                        </div>
                    </div>
                    <div class="col-12 col-md-3">
                        <div class="o_dashboard_card shadow-sm border-0 kpi-card-green bg-view p-3 rounded-4 h-100 cursor-pointer" t-on-click="() => this.openChangeRequests([['state', '=', 'pending_approval']], 'CRs Pending Approval')">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="text-uppercase text-muted fw-bold small mb-1">CR Approval Queue</h6>
                                    <h2 class="fw-bold mb-0 text-success"><t t-esc="state.data.change_requests.pending_approval"/></h2>
                                </div>
                                <div class="bg-success bg-opacity-10 p-2 rounded-3 text-success">
                                    <i class="fa fa-gavel fa-2x"/>
                                </div>
                            </div>
                            <div class="mt-2 text-muted small">Ready for management sign-off</div>
                        </div>
                    </div>
                    <div class="col-12 col-md-3">
                        <div class="o_dashboard_card shadow-sm border-0 kpi-card-blue bg-view p-3 rounded-4 h-100 cursor-default">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="text-uppercase text-muted fw-bold small mb-1">CR Financial Value</h6>
                                    <h2 class="fw-bold mb-0 text-primary">
                                        <t t-esc="(state.data.change_requests.total_cost || 0).toLocaleString()"/>
                                    </h2>
                                </div>
                                <div class="bg-primary bg-opacity-10 p-2 rounded-3 text-primary">
                                    <i class="fa fa-money fa-2x"/>
                                </div>
                            </div>
                            <div class="mt-2 text-muted small">Est. value of approved changes</div>
                        </div>
                    </div>
                </div>

                <!-- Section 3: Strategic Insights - Visual Analytics -->
                <div class="row g-4 mb-4">
                    <div class="col-12 col-lg-5">
                        <div class="card border-0 shadow-sm rounded-4 h-100">
                            <div class="card-header bg-transparent border-0 p-3 pt-4">
                                <h5 class="fw-bold mb-0"><i class="fa fa-pie-chart text-primary me-2"/> Workload Distribution</h5>
                                <div class="text-muted small">Requests by Type</div>
                            </div>
                            <div class="card-body p-3" style="min-height: 300px;">
                                <canvas t-ref="typeChart"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-lg-7">
                        <div class="card border-0 shadow-sm rounded-4 h-100">
                            <div class="card-header bg-transparent border-0 p-3 pt-4 text-white rounded-top-4" style="background: linear-gradient(135deg, #007bff, #0056b3);">
                                <h5 class="fw-bold mb-0"><i class="fa fa-line-chart me-2"/> Project Velocity</h5>
                                <div class="opacity-75 small">Monthly Creation Trends</div>
                            </div>
                            <div class="card-body p-3" style="min-height: 300px;">
                                <canvas t-ref="velocityChart"/>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-4">
                    <!-- SECTION 2: Request Pipeline + Risks -->
                    <div class="col-12 col-lg-8">
                        <div class="card border-0 shadow-sm rounded-4 mb-4 h-100">
                            <div class="card-header bg-transparent border-0 p-3 pt-4">
                                <h5 class="fw-bold mb-0"><i class="fa fa-random text-primary me-2"/> Request Pipeline</h5>
                            </div>
                            <div class="card-body p-3">
                                <div class="d-flex flex-wrap gap-2">
                                    <div t-foreach="state.data.pipeline" t-as="pipe" t-key="pipe.state" class="flex-grow-1 p-2 bg-secondary-subtle rounded-3 text-center cursor-pointer status-pill" t-on-click="() => this.openRequests([['state', '=', pipe.state]], pipe.label)">
                                        <div class="small fw-bold text-muted text-uppercase" style="font-size: 0.7em;"><t t-esc="pipe.label"/></div>
                                        <div class="h5 fw-bold mb-0"><t t-esc="pipe.count"/></div>
                                    </div>
                                </div>
                                
                                <div class="mt-5">
                                    <h6 class="fw-bold mb-3"><i class="fa fa-exclamation-triangle text-danger me-2"/> Operational Risks &amp; Blockers</h6>
                                    <div class="row g-3">
                                        <div class="col-4">
                                            <div class="p-3 bg-danger bg-opacity-10 rounded-3 text-center border-start border-4 border-danger">
                                                <div class="h3 fw-bold mb-0 text-danger"><t t-esc="state.data.risks.today_blockers"/></div>
                                                <div class="small text-muted fw-bold">Daily Blockers</div>
                                            </div>
                                        </div>
                                        <div class="col-4">
                                            <div class="p-3 bg-warning bg-opacity-10 rounded-3 text-center border-start border-4 border-warning">
                                                <div class="h3 fw-bold mb-0 text-warning"><t t-esc="state.data.risks.waiting_requests"/></div>
                                                <div class="small text-muted fw-bold">Waiting for Feedback</div>
                                            </div>
                                        </div>
                                        <div class="col-4">
                                            <div class="p-3 bg-secondary bg-opacity-10 rounded-3 text-center border-start border-4 border-dark">
                                                <div class="h3 fw-bold mb-0 text-dark"><t t-esc="state.data.risks.escalated_actions"/></div>
                                                <div class="small text-muted fw-bold">Escalations</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- SECTION 3: Analyst Workload -->
                    <div class="col-12 col-lg-4">
                        <div class="card border-0 shadow-sm rounded-4 mb-4">
                            <div class="card-header bg-transparent border-0 p-3 pt-4">
                                <h5 class="fw-bold mb-0"><i class="fa fa-users text-primary me-2"/> Analyst Workload</h5>
                            </div>
                            <div class="card-body p-3 overflow-auto" style="max-height: 480px;">
                                <div t-foreach="state.data.workload" t-as="analyst" t-key="analyst.id" class="p-3 mb-3 bg-secondary-subtle rounded-4 border-0 d-flex gap-3 align-items-center">
                                    <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center" style="width: 40px; height: 40px; flex-shrink: 0;">
                                        <i class="fa fa-user"/>
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="fw-bold mb-1"><t t-esc="analyst.name"/></div>
                                        <div class="d-flex gap-2">
                                            <span class="badge bg-primary rounded-pill small"><t t-esc="analyst.requests"/> Req</span>
                                            <span class="badge bg-info rounded-pill small"><t t-esc="analyst.action_items"/> Act</span>
                                            <span t-if="analyst.overdue > 0" class="badge bg-danger rounded-pill small"><t t-esc="analyst.overdue"/> Overdue</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-4 p-4 rounded-4 bg-primary bg-opacity-10 border-0 shadow-sm">
                    <h5 class="fw-bold text-primary mb-4"><i class="fa fa-briefcase me-2"/> Personal Cockpit: My Highlights</h5>
                    <div class="row g-3">
                        <div class="col-6 col-md-3">
                            <div class="bg-view p-3 rounded-4 shadow-sm text-center cursor-pointer my_work_card" t-on-click="() => this.openRequests(state.data.domains.my_requests || [], 'My Active Requests')">
                                <div class="h2 fw-bold text-primary mb-0"><t t-esc="state.data.my_work.requests"/></div>
                                <div class="text-muted small fw-bold">Assigned Requests</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="bg-view p-3 rounded-4 shadow-sm text-center cursor-pointer my_work_card" t-on-click="() => this.openActionItems(state.data.domains.my_actions || [], 'My Open Actions')">
                                <div class="h2 fw-bold text-info mb-0"><t t-esc="state.data.my_work.actions"/></div>
                                <div class="text-muted small fw-bold">Open Action Items</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="bg-view p-3 rounded-4 shadow-sm text-center cursor-pointer my_work_card" t-on-click="() => this.openDeliverables(state.data.domains.my_deliverables || [], 'My Deliverables')">
                                <div class="h2 fw-bold text-warning mb-0"><t t-esc="state.data.my_work.deliverables"/></div>
                                <div class="text-muted small fw-bold">My Pending Deliverables</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="bg-view p-3 rounded-4 shadow-sm text-center cursor-pointer my_work_card" t-on-click="() => this.openMeetings(state.data.domains.my_meetings || [], 'My Meetings Today')">
                                <div class="h2 fw-bold text-teal mb-0" style="color: #20c997 !important;"><t t-esc="state.data.my_work.meetings"/></div>
                                <div class="text-muted small fw-bold">My Meetings Today</div>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </div>
    </t>
</templates>
